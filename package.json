{
  "name": "homelab-landing",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Landing page for your homelab listing services",
  "main": "dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "npm run build && node dist/index.js",
    "build": "rimraf dist && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "release": "commit-and-tag-version",
    "release:pre": "commit-and-tag-version --prerelease"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gergof/homelab-landing.git"
  },
  "author": "Fandly Gergo <fandly.gergo@fndl.ro>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gergof/homelab-landing/issues"
  },
  "homepage": "https://github.com/gergof/homelab-landing#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "commit-and-tag-version": "^12.7.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/view": "^12.0.0",
    "dotenv": "^17.4.2",
    "env-var": "^7.5.0",
    "fastify": "^5.8.5",
    "nunjucks": "^3.2.4"
  },
  "commit-and-tag-version": {
    "scripts": {
      "prerelease": "git fetch --all --tags"
    },
    "types": [
      {
        "type": "feat",
        "section": "Features"
      },
      {
        "type": "fix",
        "section": "Bug Fixes"
      },
      {
        "type": "imp",
        "section": "Improvements"
      },
      {
        "type": "ci",
        "section": "Build/CI"
      },
      {
        "type": "chore",
        "hidden": true
      },
      {
        "type": "docs",
        "section": "Documentation"
      },
      {
        "type": "refactor",
        "section": "Refactor"
      },
      {
        "type": "test",
        "section": "Testing"
      }
    ]
  }
}
