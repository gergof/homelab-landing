PORT=3000
HOST=0.0.0.0
TITLE=My Homelab Server
FAVICON=
HEALTHCHECK_CACHE_TTL_SECONDS=180

# Format:
# PROJECT_N=Name;[!]URL;[healthcheck_type[|endpoint][|timeout_ms]]
#
# Prefix URL with ! when the project should be shown without an outbound web link.
# Healthcheck type can be none, http, tcp, or ping.
PROJECT_1=Router;http://10.10.0.1;http|http://10.10.0.1|5000
PROJECT_2=NAS;!smb://nas.local;ping|smb://ip2.nas.local
PROJECT_3=DNS;!8.8.8.8;ping
PROJECT_4=Dashboard;http://localhost:3000;http|/healthz|1000
PROJECT_5=Example;https://example.com;http
PROJECT_6=TCP Server Healthcheck;https://example.com;tcp|tcp://example.com:443
